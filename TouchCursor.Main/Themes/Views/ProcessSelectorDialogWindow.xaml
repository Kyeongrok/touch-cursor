<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:TouchCursor.Main.UI.Views">

    <Style TargetType="{x:Type views:ProcessSelectorDialogWindow}">
        <Setter Property="Title" Value="Select Process"/>
        <Setter Property="Width" Value="500"/>
        <Setter Property="Height" Value="450"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="ShowInTaskbar" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:ProcessSelectorDialogWindow}">
                    <Border Background="White">
                        <views:ProcessSelectorDialog x:Name="PART_DialogContent"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
