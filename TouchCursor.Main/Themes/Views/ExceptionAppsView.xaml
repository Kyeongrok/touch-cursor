<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:TouchCursor.Main.UI.Views"
                    xmlns:loc="clr-namespace:TouchCursor.Main.Localization">

    <Style TargetType="{x:Type views:ExceptionAppsView}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:ExceptionAppsView}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel Margin="5">
                            <!-- Description -->
                            <TextBlock Text="{loc:Localize ExceptionApps.Description, Default='When an excluded application is in the foreground, TouchCursor will be disabled.'}"
                                       TextWrapping="Wrap" Margin="0,4,0,10" FontSize="12" Foreground="Gray"/>

                            <!-- Excluded Process List -->
                            <TextBlock Text="{loc:Localize ExceptionApps.ExcludedApps, Default='Excluded Applications:'}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <ListBox ItemsSource="{Binding ExcludedProcessNames}"
                                     SelectedItem="{Binding SelectedProcessName}"
                                     MinHeight="150" MaxHeight="300"
                                     Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="13" Margin="4,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Add / Remove Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{loc:Localize ExceptionApps.AddApp, Default='Add...'}"
                                        Command="{Binding AddExceptionAppCommand}"
                                        Width="80" Height="28" Margin="0,0,8,0"/>
                                <Button Content="{loc:Localize ExceptionApps.RemoveApp, Default='Remove'}"
                                        Command="{Binding RemoveExceptionAppCommand}"
                                        Width="80" Height="28"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
