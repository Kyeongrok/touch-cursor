<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:TouchCursor.Main.UI.Views"
                    xmlns:loc="clr-namespace:TouchCursor.Main.Localization">

    <Style TargetType="{x:Type views:ProcessSelectorDialog}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:ProcessSelectorDialog}">
                    <Border Background="White" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Search -->
                            <TextBox x:Name="PART_SearchTextBox"
                                     Grid.Row="0"
                                     Padding="6,4"
                                     FontSize="13"
                                     Margin="0,0,0,8"/>

                            <!-- Process List -->
                            <ListView x:Name="PART_ProcessListView"
                                      Grid.Row="1"
                                      Margin="0,0,0,8"
                                      SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{loc:Localize ExceptionApps.ProcessName, Default='Process Name'}"
                                                        DisplayMemberBinding="{Binding ProcessName}"
                                                        Width="180"/>
                                        <GridViewColumn Header="{loc:Localize ExceptionApps.WindowTitle, Default='Window Title'}"
                                                        DisplayMemberBinding="{Binding WindowTitle}"
                                                        Width="250"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <!-- Buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="PART_OkButton"
                                        Content="{loc:Localize SettingsWindow.OK, Default='OK'}"
                                        Width="80" Height="28" Margin="0,0,8,0"/>
                                <Button x:Name="PART_CancelButton"
                                        Content="{loc:Localize SettingsWindow.Cancel, Default='Cancel'}"
                                        Width="80" Height="28"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
